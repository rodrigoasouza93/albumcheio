{
  "name": "albumcheio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev:web": "pnpm --filter @albumcheio/web dev",
    "dev:api": "pnpm --filter @albumcheio/api dev",
    "build:web": "pnpm --filter @albumcheio/shared build && pnpm --filter @albumcheio/web build",
    "build:api": "pnpm --filter @albumcheio/shared build && pnpm --filter @albumcheio/api build",
    "build": "pnpm --filter @albumcheio/shared build && pnpm --filter @albumcheio/api build && pnpm --filter @albumcheio/web build",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "seed:copa2026": "supabase db query --local --file supabase/seeds/copa-2026.sql",
    "seed:copa2026:teams": "supabase db query --local --file supabase/seeds/copa-2026-team-stickers-only.sql",
    "test": "pnpm --filter @albumcheio/shared test && pnpm --filter @albumcheio/api test && pnpm --filter @albumcheio/web test",
    "test:e2e": "playwright test",
    "smoke": "pnpm run build && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.7",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  }
}
